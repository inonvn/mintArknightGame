    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "Kh\xF4ng \u1ED5n r\u1ED3i c\xE0ng c\u1ED1 k\xE9o tay ra n\xF3 c\xE0ng
      h\xFAt v\xE0o s\xE2u h\u01A1n"
    NameStory: Mint
    clip: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 1
    TextStory: "Hughhh-, \u0111\u1EE1 n\xE0y"
    NameStory: Mint
    clip: {fileID: 8300000, guid: eeca5460112149e42a0cb34cc2e02c12, type: 3}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: "C\xF4 g\xE1i m\xE8o k\xEDch ho\u1EA1t Arts gi\xF3 nh\u1EAFm th\u1EB3ng
      v\xE0o c\xE1nh tay c\u1EE7a m\xECnh nh\u01B0ng n\xF3 \u0111\xE3 b\u1ECB v\xF4
      hi\u1EC7u h\xF3a b\u1EB1ng m\u1ED9t c\xE1ch n\xE0o \u0111\xF3."
    NameStory: Mint
    clip: {fileID: 8300000, guid: eeca5460112149e42a0cb34cc2e02c12, type: 3}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "M\u1ED9t l\u1EA7n n\u1EEFa"
    NameStory: Mint
    clip: {fileID: 8300000, guid: eeca5460112149e42a0cb34cc2e02c12, type: 3}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 1
    TextStory: 
    NameStory: Mint
    clip: {fileID: 8300000, guid: eeca5460112149e42a0cb34cc2e02c12, type: 3}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: Ah-
    NameStory: Mint
    clip: {fileID: 8300000, guid: eeca5460112149e42a0cb34cc2e02c12, type: 3}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
