    imgNV: {fileID: 21300000, guid: 0cb31d0179a8b6541b4ab2bd76da0701, type: 3}
    Background: {fileID: 21300000, guid: 9a0e48b81be388f43a2989bbc700712d, type: 3}
    textChoose: []
  - state: 4
    TextStory: "HoneyBerry c\xF4 kh\xF4ng c\u1EA7n ph\u1EA3i b\xEAnh c\xF4 ta."
