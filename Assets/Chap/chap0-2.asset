  - state: 6
    TextStory: "C\xF4 g\xE1i m\xE8o b\u01B0\u1EDBc \u0111i trong kho\u1EA3ng kh\xF4ng
      gian v\xF4 t\u1EADn."
    NameStory: 
    clip: {fileID: 8300000, guid: e563141ee151865408660f12eed3eea1, type: 3}
    soundType: 2
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "T\u1EEBng b\u01B0\u1EDBc \u0111i m\u1ED9t c\xF4 \u0111\u1EC1u nh\xECn
      xung quanh hy v\u1ECDng s\u1EBD t\xECm th\u1EA5y g\xEC \u0111\xF3 ngo\xE0i
      s\u1EF1 tr\u1EAFng x\xF3a c\u1EE7a kh\xF4ng gian"
    NameStory: 
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "L\xE0 m\u1ED9t ng\u01B0\u1EDDi nghi\xEAn c\u1EE9u \u0111\u1ECBa ch\u1EA5t
      c\xF4 v\u1ED1n \u0111\xE3 quen v\u1EDBi vi\u1EC7c \u0111i b\u1ED9 \u0111\u01B0\u1EDDng
      d\xE0i."
    NameStory: 
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "Nh\u01B0ng vi\u1EC7c \u0111i b\u1ED9 trong kh\xF4ng gian n\xE0y khi\u1EBFn
      c\xF4 c\u1EA3m th\u1EA5y kh\xF3 ch\u1ECBu l\u1EA1 th\u01B0\u1EDDng."
    NameStory: 
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "L\xFAc tr\u01B0\u1EDBc m\xECnh t\u1EEBng \u0111\u01B0\u1EE3c nghe
      r\u1EB1ng Iris c\xF3 th\u1EC3 t\u1EA1o ra m\u1ED9i gi\u1EA5c m\u01A1 ch\xE2n
      th\u1EF1c cho nh\u1EEFng \u0111\u1EE9a tr\u1EBB."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "C\xF3 th\u1EC3 \u0111\xE2y l\xE0 m\u1ED9t d\u1EA1ng Arts n\xE0o \u0111\xF3
      t\u01B0\u01A1ng t\u1EF1 ch\u0103ng ?"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "N\u1EBFu \u0111\xE2y l\xE0 gi\u1EA5c m\u01A1 th\xEC vi\u1EC7c c\xF3
      c\u1EA3m gi\xE1c \u0111au khi v\xE9o m\xE1 s\u1EBD kh\xF4ng t\u1ED3n t\u1EA1i"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: "C\xF4 g\xE1i m\xE8o v\xE9o nh\u1EB9 b\xEAn m\xE1 c\u1EE7a m\xECnh,
      c\u1EA3m gi\xE1c \u0111au l\xE0 th\u1EE9 ngay l\u1EADp t\u1EE9c c\xF4 c\u1EA3m
      nh\u1EADn \u0111\u01B0\u1EE3c."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "V\u1EADy \u0111\xE2y kh\xF4ng ph\u1EA3i l\xE0 m\u01A1."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "Li\u1EC7u \u0111\xE2y c\xF3 ph\u1EA3i l\xE0 m\u1ED9t lo\u1EA1i Arts
      b\xF3p m\xE9o kh\xF4ng gian kh\xF4ng ?"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "M\xECnh t\u1EEBng \u0111\u1ECDc m\u1ED9t cu\u1ED1n s\xE1ch v\u1EC1
      \"Witch king\" cho r\u1EB1ng \xF4ng ta \u0111\xE3 t\u1EA1o ra m\u1ED9t kh\xF4ng
      gian ri\xEAng bi\u1EC7t ch\u1EC9 b\u1EB1ng Arts c\u1EE7a b\u1EA3n th\xE2n."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "N\u1EBFu \u0111\xF3 l\xE0 th\u1EADt th\xEC ng\u01B0\u1EDDi t\u1EA1o
      ra n\u01A1i n\xE0y kh\xE1 nguy hi\u1EC3m."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "Nh\u01B0ng t\u1EA1i sao m\xECnh l\u1EA1i \u1EDF \u0111\xE2y "
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "N\u1EBFu kh\xF4ng nh\u1EA7m, h\xF4m qua m\xECnh \u0111\u1EBFn th\u01B0
      vi\u1EC7n c\u1EE7a rhodes island sau khi \u0111i kh\u1EA3o s\xE1t \u0111\u1ECBa
      ch\u1EA5t v\u1EDBi Skyfire."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "R\u1ED3i sau \u0111\xF3 m\xECnh ng\u1EE7 g\u1EADt tr\xEAn b\xE0n."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "R\u1ED3i sau \u0111\xF3-."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "Huh ?, \u0111\xF3 l\xE0 g\xEC v\u1EADy ?"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: "D\xF2ng suy ngh\u0129 c\u1EE7a c\xF4 b\u1ECB ng\u1EAFt qu\xE3ng b\u1EDFi
      \xE1nh s\xE1ng ph\xE1t ra t\u1EEB v\u1EADt th\u1EC3 ph\xEDa tr\u01B0\u1EDBc."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "N\xF3 tr\xF4ng gi\u1ED1ng c\xE1i g\u01B0\u01A1ng v\u1EADy ch\u1EC9
      l\xE0 n\xF3 kh\xF4ng hi\u1EC7n l\u1EA1i b\u1EA5t k\xEC h\xECnh \u1EA3nh g\xEC
      \u1EDF tr\u01B0\u1EDBc n\xF3."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "C\xF3 v\u1EBB nh\u01B0 n\xF3 h\u1EA5p th\u1EE5 \xE1nh s\xE1ng xung
      quanh \u0111\u1EC3 ph\xE1t s\xE1ng."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "N\xF3 l\xE0m t\u1EEB ch\u1EA5t li\u1EC7u g\xEC ?"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "T\u1EA1i sao n\xF3 c\xF3 th\u1EC3 h\u1EA5p th\u1EE5 \xE1nh s\xE1ng
      \u0111\u01B0\u1EE3c ?"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: 62b83d5aa36e6574da31e65802ea68ce, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "Li\u1EC7u \u0111\xE2y c\xF3 ph\u1EA3i l\xE0 m\u1ED9t lo\u1EA1i c\xF4ng
      c\u1EE5 Arts kh\xF4ng ?"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "L\xE0m sao m\xECnh kh\xF4ng h\u1EC1 nh\xECn th\u1EA5y n\xF3 t\u1EEB
      xa m\u1EB7c cho k\xEDch th\u01B0\u1EDBc c\u0169ng nh\u01B0 h\xECnh d\u1EA1ng
      c\u1EE7a n\xF3 ?"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "\u0110i\u1EC1u \u0111\xF3 khi\u1EBFn m\xECnh c\xE0ng c\u1EA3m th\u1EA5y
      t\xF2 m\xF2"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: " C\xF4 \u0111\u01B0a tay ra ch\u1EA1m v\xE0o chi\u1EBFc g\u01B0\u01A1ng
      \u0111\u1EC3 th\u1ECFa m\xE3n s\u1EF1 t\xF2 m\xF2 nh\u1EA5t th\u1EDDi c\u1EE7a
      b\u1EA3n th\xE2n"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: "\u0110\u1ED9t nhi\xEAn c\xF4 nh\u1EDB l\u1EA1i m\u1ED9t l\u1EA7n
      Skyfire m\u1EAFng c\xF4 v\xEC \u0111\xE3 \u0111i l\u1EA1c kh\u1ECFi \u0111o\xE0n
      v\xE0 khi\u1EBFn cho b\u1EA3n th\xE2n b\u1ECB th\u01B0\u01A1ng."
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 3
    TextStory: "Con m\xE8o ngu ng\u1ED1c!!"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: e22fce4d813792f48adf937d97ac3743, type: 3}
    Background: {fileID: 21300000, guid: 9a0e48b81be388f43a2989bbc700712d, type: 3}
    textChoose: []
  - state: 4
    TextStory: "Skyfire b\xECnh t\u0129nh n\xE0o c\u1EADu ta an to\xE0n r\u1ED3i,
      c\u1EADu kh\xF4ng c\u1EA7n ph\u1EA3i m\u1EAFng c\u1EADu ta n\u1EEFa \u0111\xE2u."
    NameStory: HoneyBerry
    clip: {fileID: 0}
    soundType: 0
