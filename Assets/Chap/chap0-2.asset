    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: db0acbb83c80c6f4d9c0726337991e30, type: 3}
    Background: {fileID: 21300000, guid: 9a0e48b81be388f43a2989bbc700712d, type: 3}
    textChoose: []
  - state: 4
    TextStory: "C\xE1i l\xED do v\xEC m\xECnh th\u1EA5y c\xF3 m\u1EA3nh qu\u1EB7ng
      qu\xFD hi\u1EBFm n\xEAn m\xECnh \u0111\xE3 v\xF4 t\xECnh t\xE1ch \u0111o\xE0n
      \u0111\u1EC3 thu th\u1EADp ch\xFAng ch\u1EB3ng h\u1EE3p l\xED m\u1ED9t ch\xFAt
