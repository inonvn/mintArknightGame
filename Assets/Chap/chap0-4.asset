    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: "C\xF4 ho s\u1EB7c s\u1EE5a ngay sau khi u\u1ED1ng \u0111\u01B0\u1EE3c
      m\u1ED9t ch\xFAt n\u01B0\u1EDBc c\xF2n chi\u1EBFc b\xECnh th\xEC r\u01A1i xu\u1ED1ng
      \u0111\u1EA5t v\u1EE1 tan th\xE0nh nh\u1EEFng m\u1EA3nh s\u1EE9 s\u1EAFc l\u1EA1nh"
    NameStory: 
    clip: {fileID: 8300000, guid: de441df6445ca554ba3ed38af0bd60a5, type: 3}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "N\u01B0\u1EDBc m\u1EAFt c\xF4 tr\xE0o ra v\xEC c\u1EA3m gi\xE1c s\u1EB7c
      n\u01B0\u1EDBc, \xE1o v\xE0 v\xE1y c\xF4 c\u0169ng b\u1ECB \u01B0\u1EDBt m\u1ED9t
      ph\u1EA7n."
    NameStory: 
    clip: {fileID: 8300000, guid: de441df6445ca554ba3ed38af0bd60a5, type: 3}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "C\xF4 bi\u1EBFt b\u1EA3n th\xE2n n\xEAn r\xF3t n\u01B0\u1EDBc ra
      c\u1ED1c \u0111\u1EC3 tr\xE1nh \u01B0\u1EDBt hay \xEDt ra c\u0169ng ph\u1EA3i
      u\u1ED1ng t\u1EEB t\u1ED1n."
    NameStory: 
    clip: {fileID: 8300000, guid: de441df6445ca554ba3ed38af0bd60a5, type: 3}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "C\xF4 bi\u1EBFt b\u1EA3n th\xE2n kh\xF4ng n\xEAn u\u1ED1ng nh\u1EEFng
      th\u1EE9 kh\xF4ng ch\u1EAFc ch\u1EAFn."
    NameStory: 
    clip: {fileID: 8300000, guid: de441df6445ca554ba3ed38af0bd60a5, type: 3}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "C\xF4 bi\u1EBFt b\u1EA3n th\xE2n c\xF4 c\u1EF1c k\xEC t\u1EC7 l\xFAc
      n\xE0y."
    NameStory: 
    clip: {fileID: 8300000, guid: de441df6445ca554ba3ed38af0bd60a5, type: 3}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "C\xF4 bi\u1EBFt h\u1EBFt m\u1ECDi th\u1EE9 c\u0169ng nh\u01B0 l\xFD
      thuy\u1EBFt nh\u01B0ng ph\u1EA7n b\u1EA3n n\u0103ng c\u1EE7a c\xF4 khi\u1EBFn
      c\xF4 x\u1EED l\xED m\u1ECDi th\u1EE9 m\u1ED9t c\xE1ch sai l\u1EA7m."
    NameStory: 
    clip: {fileID: 8300000, guid: de441df6445ca554ba3ed38af0bd60a5, type: 3}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "C\xF4 c\u1ED1 b\xECnh t\u0129nh l\u1EA1i r\u1ED3i nh\xECn xung quanh
      c\u0103n ph\xF2ng c\xF4 \u0111ang \u1EDF."
