    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "Ngay l\u1EADp t\u1EE9c c\xF4 v\u1ED3 l\u1EA5y r\u1ED3i m\u1EDF mi\u1EC7ng
      r\xF3t l\u01B0\u1EE3ng l\u1EDBn n\u01B0\u1EDBc b\xEAn trong \u0111\xF3 v\xE0o
      m\u1EB7c cho vi\u1EC7c n\u01B0\u1EDBc ch\u1EA3y ra th\u1EA5m v\xE0o v\xE1y
      v\xE0 \xE1o kho\xE1c c\u1EE7a c\xF4."
    NameStory: 
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 0}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "Kh\u1EE5-"
    NameStory: Mint
    clip: {fileID: 0}
    soundType: 0
    backGroundMusic: {fileID: 0}
    imgNV: {fileID: 21300000, guid: d4ca2eb323dfc0541987d95a2e3d9133, type: 3}
