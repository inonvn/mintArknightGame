  - state: 4
    TextStory: "L\xFAc n\xE0y m\xECnh nh\xECn t\u1EC7 l\u1EAFm."
    NameStory: Mint
    clip: {fileID: 0}
    imgNV: {fileID: 21300000, guid: d4ca2eb323dfc0541987d95a2e3d9133, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "m\xECnh ph\u1EA3i \u0111i r\u1EEDa m\u1EB7t tr\xE1nh \u0111\u1EC3
      ng\u01B0\u1EDDi kh\xE1c lo l\u1EAFng"
    NameStory: Mint
    clip: {fileID: 0}
    imgNV: {fileID: 21300000, guid: d4ca2eb323dfc0541987d95a2e3d9133, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: "C\xF4 g\xE1i m\xE8o b\u01B0\u1EDBc v\xE0o nh\xE0 t\u1EAFm r\u1ED3i
      nh\xECn b\u1EA3n th\xE2n c\xF4 trong g\u01B0\u01A1ng"
    NameStory: Mint
    clip: {fileID: 0}
    imgNV: {fileID: 21300000, guid: d4ca2eb323dfc0541987d95a2e3d9133, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "Nh\xECn ti\u1EC1u t\u1EE5y th\u1EADt"
    NameStory: Mint
    clip: {fileID: 0}
    imgNV: {fileID: 21300000, guid: d4ca2eb323dfc0541987d95a2e3d9133, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 6
    TextStory: "C\xF4 m\u1EC9m c\u01B0\u1EDDi t\u1EF1 tr\xE1ch b\u1EA3n th\xE2n m\xECnh
      \u0111\xE3 b\u1ECF b\xEA vi\u1EC7c ch\u0103m s\xF3c b\u1EA3n th\xE2n, r\u1ED3i
      c\xF4 b\u1EAFt \u0111\u1EA7u x\u1EA3 n\u01B0\u1EDBc \u0111\u1EC3 lau qua khu\xF4n
      m\u1EB7t m\xECnh."
    NameStory: Mint
    clip: {fileID: 0}
    imgNV: {fileID: 21300000, guid: d4ca2eb323dfc0541987d95a2e3d9133, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 4
    TextStory: "M\xECnh c\u1EA3m th\u1EA5y c\xF3 l\u1ED7i v\u1EDBi ch\u1ECB Iris
      khi l\xE0m v\u1EE1 c\xE1i b\xECnh s\u1EE9 ch\u1ECB \u1EA5y t\u1EB7ng m\xECnh
      qu\xE1."
    NameStory: Mint
    clip: {fileID: 0}
    imgNV: {fileID: 21300000, guid: cedebc57ee3d336419214ac68c070a54, type: 3}
    Background: {fileID: 0}
    textChoose: []
  - state: 0
    TextStory: "M\u1EA5y c\xE1i m\u1EA3nh s\u1EE9 kia ch\u1EAFc ch\u1ED1c n\u1EEFa
